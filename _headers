# Netlify/Cloudflare Pages cache headers — immutable fingerprint-style caching
# for heavy static assets. Frames/videos/fonts never change without new names.

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/libs/*
  Cache-Control: public, max-age=31536000, immutable

/css/*
  Cache-Control: public, max-age=31536000, immutable

/*.html
  Cache-Control: public, max-age=0, must-revalidate

# the root URL is not matched by /*.html
/
  Cache-Control: public, max-age=0, must-revalidate
